/** 全局样式 **/
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 状态标签 */
.tag-normal {
  background: #E8F5E9;
  color: #2E7D32;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-expiring {
  background: #FFF3E0;
  color: #E65100;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-expired {
  background: #FFEBEE;
  color: #C62828;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-usedup {
  background: #ECEFF1;
  color: #546E7A;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.empty-state text {
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 加载 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
