/** 药品列表页 */
.page { padding-bottom: 40rpx; }

/* 搜索 */
.search-bar {
  display: flex;
  margin: 20rpx 30rpx;
  align-items: center;
  gap: 16rpx;
}
.search-input {
  flex: 1;
  background: #fff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-btn {
  background: #07C160;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 筛选标签 */
.filter-tabs {
  white-space: nowrap;
  padding: 0 30rpx 20rpx;
}
.tab {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
  border: 1rpx solid #eee;
}
.tab.active {
  background: #07C160;
  color: #fff;
  border-color: #07C160;
}

/* 排序 */
.sort-bar {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx 16rpx;
}
.sort-item {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
}
.sort-item.active { color: #07C160; background: #E8F5E9; }

/* 药品卡片 */
.medicine-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 30rpx 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.medicine-name { font-size: 30rpx; font-weight: bold; }
.card-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.card-row .label { font-size: 26rpx; color: #999; }
.card-row .value { font-size: 26rpx; color: #333; }
.text-red { color: #C62828; }

/* 加载 */
.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.add-btn {
  margin-top: 30rpx;
  background: #07C160;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}
