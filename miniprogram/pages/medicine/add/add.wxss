/** 新增药品页 */
.page { padding-bottom: 120rpx; }

.form-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.form-label.required::before {
  content: '*';
  color: #C62828;
  margin-right: 4rpx;
}
.form-input {
  font-size: 30rpx;
  padding: 8rpx 0;
  width: 100%;
}
.form-textarea {
  font-size: 30rpx;
  padding: 8rpx 0;
  width: 100%;
  height: 120rpx;
}
.form-row {
  display: flex;
  gap: 30rpx;
}
.half {
  flex: 1;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-value {
  font-size: 30rpx;
  padding: 8rpx 0;
  color: #333;
}
.picker-value.placeholder { color: #ccc; }
.expiry-picker {
  color: #E65100 !important;
  font-weight: bold;
}
.expiry-picker.placeholder { color: #ccc !important; font-weight: normal; }

.submit-area {
  margin: 40rpx 30rpx;
}
