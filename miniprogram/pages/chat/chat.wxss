/** AI 聊天页 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

/* 欢迎页 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}
.welcome-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.welcome-title { font-size: 36rpx; font-weight: bold; margin-bottom: 12rpx; }
.welcome-desc { font-size: 28rpx; color: #999; margin-bottom: 30rpx; }
.tips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  width: 100%;
}
.tip-item {
  background: #fff;
  border: 2rpx solid #E0E0E0;
  border-radius: 50rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}
.tip-item:active { background: #f0f0f0; }

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}
.msg-row.user {
  justify-content: flex-end;
}
.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.user-avatar {
  background: #07C160;
  margin-left: 16rpx;
}
.ai-avatar {
  background: #E3F2FD;
  margin-right: 16rpx;
}
.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.user-bubble {
  background: #07C160;
  color: #fff;
  border-radius: 16rpx 4rpx 16rpx 16rpx;
}
.ai-bubble {
  background: #fff;
  color: #333;
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.loading-dots { animation: blink 1.2s infinite; }
@keyframes blink {
  0% { opacity: .2; }
  50% { opacity: 1; }
  100% { opacity: .2; }
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 30rpx;
  border-top: 2rpx solid #f0f0f0;
  gap: 16rpx;
}
.msg-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
}
.send-btn {
  background: #ccc;
  color: #fff;
  padding: 16rpx 36rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}
.send-btn.active { background: #07C160; }
