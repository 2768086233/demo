<view class="page">
  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-with-animation="true"
               scroll-into-view="msg-{{messages.length - 1}}"
               upper-threshold="0">
    <view wx:if="{{messages.length === 0}}" class="welcome">
      <text class="welcome-icon">🤖</text>
      <text class="welcome-title">AI 用药助手</text>
      <text class="welcome-desc">你可以问我：</text>
      <view class="tips">
        <text class="tip-item" bindtap="sendQuick" data-msg="这个药过期了还能吃吗？">💊 过期药还能吃吗？</text>
        <text class="tip-item" bindtap="sendQuick" data-msg="感冒药和退烧药能一起吃吗？">🤒 感冒药能一起吃吗？</text>
        <text class="tip-item" bindtap="sendQuick" data-msg="帮我整理一下家庭药箱清单">📋 整理药箱清单</text>
        <text class="tip-item" bindtap="sendQuick" data-msg="药品应该怎么保存">🏠 药品保存方法</text>
      </view>
    </view>

    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <!-- 用户消息 -->
      <view wx:if="{{item.role === 'user'}}" class="msg-row user">
        <view class="msg-bubble user-bubble">{{item.content}}</view>
        <view class="msg-avatar user-avatar">👤</view>
      </view>
      <!-- AI 消息 -->
      <view wx:else class="msg-row ai">
        <view class="msg-avatar ai-avatar">🤖</view>
        <view class="msg-bubble ai-bubble">
          <text wx:if="{{item.loading}}">思考中<text class="loading-dots">...</text></text>
          <text wx:else>{{item.content}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区 -->
  <view class="input-bar">
    <input class="msg-input" placeholder="输入你的问题..."
           value="{{inputText}}" bindinput="onInput"
           bindconfirm="sendMessage" confirm-type="send" />
    <view class="send-btn {{inputText.trim() ? 'active' : ''}}" bindtap="sendMessage">发送</view>
  </view>
</view>
