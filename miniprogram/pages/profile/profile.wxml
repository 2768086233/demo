<!-- 个人中心页 -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-card" bindtap="login" wx:if="{{!isLoggedIn}}">
    <view class="avatar-placeholder">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="login-tip">
      <text class="login-title">点击登录</text>
      <text class="login-desc">微信一键登录，管理你的药品</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <view class="user-card" wx:else>
    <view class="avatar">
      <image class="avatar-img" src="{{userInfo.avatarUrl || '/images/profile.png'}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '用户'}}</text>
      <text class="user-id">ID: {{userInfo.id}}</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToNotifications">
      <text class="menu-icon">🔔</text>
      <text class="menu-text">消息提醒</text>
      <text class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToStatistics">
      <text class="menu-icon">📊</text>
      <text class="menu-text">数据统计</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="menu-card">
    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">版本号</text>
      <text class="menu-extra">v1.0.0</text>
    </view>
  </view>

  <!-- 退出 -->
  <view class="logout-area" wx:if="{{isLoggedIn}}">
    <button class="btn-logout" bindtap="onLogout">退出登录</button>
  </view>
</view>
