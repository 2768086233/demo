/** 消息页 */
.page { padding-bottom: 40rpx; }

.unread-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #E3F2FD;
  margin: 0 30rpx 20rpx;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1565C0;
}
.mark-all { color: #07C160; font-weight: bold; }

/* 滑动项容器 - 固定宽度，溢出隐藏 */
.swipe-item {
  margin: 0 30rpx 12rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

/* 滑动内容+删除按钮的内层容器 */
.swipe-inner {
  display: flex;
  width: calc(100% + 140rpx);
  transition: transform 0.2s ease;
}

.swipe-content {
  width: calc(100% - 140rpx);
  background: #fff;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.swipe-content.unread {
  border-left: 6rpx solid #07C160;
}

.swipe-delete {
  width: 140rpx;
  flex-shrink: 0;
  background: #E53935;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 0 12rpx 12rpx 0;
}

/* 通知条目 */
.notif-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  gap: 16rpx;
}
.notif-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}
.notif-dot.dot { background: #07C160; }
.notif-content { flex: 1; min-width: 0; }
.notif-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.notif-type { font-size: 28rpx; font-weight: bold; }
.notif-time { font-size: 22rpx; color: #999; flex-shrink: 0; }
.notif-desc {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }

.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
